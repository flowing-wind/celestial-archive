---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config/siteConfig";

interface Props {
    title: string;
    description?: string;
}

const { title, description = siteConfig.site.description } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/logo.svg" />
        <meta name="generator" content={Astro.generator} />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
        />
        <title>{title} | {siteConfig.site.title}</title>
    </head>
    <body>
        <Header />
        <main>
            <slot />
        </main>
        <Footer />

        <!-- Background Starry/Dust Effect Container -->
        <div class="stars-container" aria-hidden="true"></div>
    </body>
</html>

<script>
    // Simple starry background generator
    function generateStars() {
        const container = document.querySelector(".stars-container");
        if (!container) return;

        const numStars = 60; // Make it less dense
        for (let i = 0; i < numStars; i++) {
            const star = document.createElement("div");
            star.className = "star";
            star.style.left = `${Math.random() * 100}%`;
            star.style.top = `${Math.random() * 100}%`;
            star.style.animationDelay = `${Math.random() * 5}s`;
            star.style.opacity = (Math.random() * 0.4).toString(); // Make them darker initially

            // Random size between 1px and 2px
            const size = Math.random() * 1.5 + 1;
            star.style.width = `${size}px`;
            star.style.height = `${size}px`;

            container.appendChild(star);
        }
    }

    // Run on initial load and setup view transitions if needed
    document.addEventListener("DOMContentLoaded", generateStars);
</script>

<style is:global>
    html,
    body {
        height: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    main {
        flex: 1;
        width: 100%;
        max-width: var(--max-width-content);
        margin: 0 auto;
        padding: 2rem var(--spacing-base);
        position: relative;
        z-index: 10;
    }

    /* CSS Starry Sky Effect */
    .stars-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
        background: transparent;
        overflow: hidden;
    }

    .star {
        position: absolute;
        background-color: var(--accent-gold);
        border-radius: 50%;
        box-shadow: var(--shadow-celestial);
        animation: twinkle 4s infinite ease-in-out alternate;
    }

    @keyframes twinkle {
        0% {
            opacity: 0.1;
            transform: scale(0.8);
        }
        100% {
            opacity: 0.6; /* Dimmer max brightness */
            transform: scale(1.1);
            box-shadow: 0 0 5px rgba(232, 204, 129, 0.5); /* subdued glow */
        }
    }
</style>
