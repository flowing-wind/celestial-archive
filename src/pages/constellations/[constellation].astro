---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../config/siteConfig";

export async function getStaticPaths() {
    const observations = await getCollection("observations");

    // Extract unique constellations
    const uniqueConstellations = [
        ...new Set(observations.map((obs) => obs.data.constellation)),
    ];

    return uniqueConstellations.map((constellation) => {
        // Find all observations belonging to this constellation
        const filteredPosts = observations
            .filter((obs) => obs.data.constellation === constellation)
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

        return {
            // URL slug format (e.g., "Groups of Intrigue" -> "groups-of-intrigue")
            params: {
                constellation: constellation.toLowerCase().replace(/\s+/g, "-"),
            },
            props: {
                constellationName: constellation,
                entries: filteredPosts,
            },
        };
    });
}

const { constellationName, entries } = Astro.props;

const introLore =
    siteConfig.constellationsLore[constellationName] ||
    "Undocumented records awaiting the Archivist's classification.";
---

<Layout title={`${constellationName} | ${siteConfig.site.title}`}>
    <main class="collection-main">
        <a href="/constellations" class="back-link">
            <span class="material-symbols-outlined">west</span>
            Return to Constellations
        </a>

        <header class="collection-header">
            <h1 class="page-title">{constellationName}</h1>

            <div class="lore-preface">
                <div class="ornate-divider">
                    <span class="divider-line"></span>
                    <span class="material-symbols-outlined star-icon"
                        >star_rate</span
                    >
                    <span class="divider-line"></span>
                </div>

                <p class="lore-text">{introLore}</p>

                <div class="ornate-divider">
                    <span class="divider-line"></span>
                    <span class="material-symbols-outlined star-icon"
                        >star_rate</span
                    >
                    <span class="divider-line"></span>
                </div>
            </div>
        </header>

        <section class="entries-list">
            {
                entries.map((entry) => (
                    <article class="entry-row">
                        <div class="entry-meta-side">
                            <time class="entry-date">
                                {entry.data.date.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "short",
                                    day: "numeric",
                                })}
                            </time>
                            <span class="entry-author">
                                by {entry.data.author}
                            </span>
                        </div>

                        <div class="entry-content-side">
                            <h2 class="entry-title">
                                <a href={`/observations/${entry.slug}`}>
                                    {entry.data.title}
                                </a>
                            </h2>
                            <p class="entry-description">
                                {entry.data.description}
                            </p>
                        </div>
                    </article>
                ))
            }
        </section>

        <div class="footer-back-link">
            <a href="/constellations" class="back-link bottom-link">
                <span class="material-symbols-outlined">west</span>
                Back to Index
            </a>
        </div>
    </main>
</Layout>

<style>
    .collection-main {
        max-width: 850px; /* Kept tight to ensure dense reading structure */
        margin: 0 auto;
        padding: 4rem var(--spacing-base);
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-serif-elegant);
        font-size: 1rem;
        color: rgba(207, 170, 107, 0.7);
        text-decoration: none;
        transition: var(--transition-smooth);
        margin-bottom: 3rem;
    }

    .back-link:hover {
        color: var(--accent-gold-glow);
        text-shadow: 0 0 10px rgba(207, 170, 107, 0.3);
    }

    .back-link .material-symbols-outlined {
        font-size: 1.2rem;
        transition: transform 0.3s ease;
        text-transform: none !important;
    }

    .back-link:hover .material-symbols-outlined {
        transform: translateX(-5px);
    }

    .collection-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .page-title {
        font-family: var(--font-serif-display);
        font-size: 3.5rem;
        color: var(--accent-gold);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 2rem;
        text-shadow: var(--shadow-celestial);
    }

    .lore-preface {
        padding: 0 2rem;
    }

    .lore-text {
        font-family: var(--font-serif-elegant);
        font-size: 1.25rem;
        color: #d1c8b3; /* Bright parchment tone from user request */
        text-shadow: 0 0 10px rgba(207, 170, 107, 0.1);
        font-style: italic;
        line-height: 1.7;
        margin: 2rem 0;
        text-align: justify;
        text-align-last: center; /* Center the last line of justified text */
    }

    .ornate-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .divider-line {
        height: 1px;
        width: 150px;
        background: linear-gradient(
            90deg,
            transparent,
            var(--border-gold),
            transparent
        );
    }

    .star-icon {
        color: var(--accent-gold);
        font-size: 1.2rem;
        text-transform: none !important;
    }

    /* Dense Entry List Design */
    .entries-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .entry-row {
        display: flex;
        align-items: flex-start;
        gap: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px dashed rgba(207, 170, 107, 0.15);
        transition: var(--transition-smooth);
    }

    .entry-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .entry-row:hover {
        background: linear-gradient(
            90deg,
            transparent,
            rgba(207, 170, 107, 0.03),
            transparent
        );
    }

    .entry-meta-side {
        flex: 0 0 120px;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        text-align: right;
        padding-top: 0.3rem; /* Visual alignment with title height */
    }

    .entry-date {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--accent-gold);
        margin-bottom: 0.2rem;
    }

    .entry-author {
        font-family: var(--font-serif-elegant);
        font-size: 0.8rem;
        color: var(--text-ash-gray);
        font-style: italic;
    }

    .entry-content-side {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .entry-title {
        margin: 0;
        font-family: var(--font-serif-elegant);
        font-size: 1.5rem;
        line-height: 1.2;
    }

    .entry-title a {
        color: #d1c8b3; /* Bright parchment tone per user request */
        text-shadow: 0 0 10px rgba(207, 170, 107, 0.1);
        text-decoration: none;
        transition: var(--transition-smooth);
        display: inline-block;
    }

    .entry-title a:hover {
        color: var(--accent-gold-glow);
        text-shadow: 0 0 15px rgba(207, 170, 107, 0.4);
        transform: translateX(3px);
    }

    .entry-description {
        margin: 0;
        font-family: var(--font-body);
        font-size: 0.95rem;
        color: var(--text-ash-gray);
        line-height: 1.5;
        /* Line clamping to keep things extremely compact */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .footer-back-link {
        margin-top: 4rem;
        text-align: center;
        border-top: 1px solid rgba(207, 170, 107, 0.2);
        padding-top: 2rem;
    }

    .bottom-link {
        margin-bottom: 0;
    }

    @media (max-width: 650px) {
        .entry-row {
            flex-direction: column;
            gap: 0.5rem;
        }

        .entry-meta-side {
            flex: auto;
            align-items: flex-start;
            text-align: left;
            flex-direction: row;
            gap: 0.8rem;
            padding-top: 0;
        }

        .entry-date::after {
            content: "•";
            color: var(--border-gold);
            margin-left: 0.8rem;
        }

        .page-title {
            font-size: 2.5rem;
        }

        .lore-preface {
            padding: 0;
        }
    }
</style>
