---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

// Fetch up to 15 most recent observations for client-side pagination
const allObservations = await getCollection("observations");
const recentObservations = allObservations
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 15);

// Extract all unique constellations dynamically
const uniqueConstellations = [
	...new Set(allObservations.map((obs) => obs.data.constellation)),
].sort();

import { siteConfig } from "../config/siteConfig";
---

<Layout title={siteConfig.site.title}>
	<section class="hero-section">
		<div class="hero-content">
			<h1 class="hero-title">{siteConfig.hero.title}</h1>
			<p class="hero-subtitle">
				{siteConfig.hero.subtitle}
			</p>

			<div class="ornate-divider">
				<span class="star-icon">✦</span>
				<span class="line"></span>
				<span class="star-icon">✦</span>
			</div>

			<p class="hero-intro">
				{siteConfig.hero.intro}
			</p>
		</div>
	</section>

	<section class="content-section">
		<div class="section-header">
			<h2 class="section-title">Recent Observations</h2>
		</div>

		<div class="card-grid" id="observations-grid">
			{
				recentObservations.map((obs, index) => (
					<div class="pagination-item obs-item" data-index={index}>
						<Card
							title={obs.data.title}
							description={obs.data.description}
							url={`/observations/${obs.slug}`}
							date={obs.data.date.toISOString().split("T")[0]}
							author={obs.data.author}
							category={obs.data.constellation}
						/>
					</div>
				))
			}
		</div>

		<div
			class="pagination-container"
			id="observations-pagination"
			data-total={recentObservations.length}
		>
			<!-- Controls injected by JS -->
		</div>
	</section>

	<section class="content-section">
		<div class="section-header">
			<h2 class="section-title">Explore by Constellation</h2>
		</div>

		<div class="collections-grid" id="constellations-grid">
			{
				uniqueConstellations.map((constellationName, index) => (
					<div class="pagination-item const-item" data-index={index}>
						<a
							href={`/constellations/${constellationName.toLowerCase().replace(/\s+/g, "-")}`}
							class="collection-item"
						>
							<div
								class="collection-bg"
								style="background-image: radial-gradient(circle at center, rgba(45,31,20,0.8), var(--bg-dark-night));"
							/>
							<h3 class="collection-title">
								{constellationName}
							</h3>
							<p class="collection-lore">
								{siteConfig.constellationsLore[
									constellationName
								] ||
									"Undocumented records awaiting the Archivist's classification."}
							</p>
						</a>
					</div>
				))
			}
		</div>

		<div
			class="pagination-container"
			id="constellations-pagination"
			data-total={uniqueConstellations.length}
		>
			<!-- Controls injected by JS -->
		</div>
	</section>
</Layout>

<style>
	/* Hero Section */
	.hero-section {
		min-height: 45vh; /* Reduced height to pull up recent observations */
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 3rem 0 1rem;
		position: relative;
	}

	.hero-content {
		max-width: 800px;
		position: relative;
		z-index: 10;
	}

	.hero-title {
		font-size: clamp(3rem, 8vw, 5rem);
		color: var(--accent-gold-glow);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: 0.5rem;
		text-shadow: 0 0 20px rgba(207, 170, 107, 0.4);
		line-height: 1.1;
	}

	.hero-subtitle {
		font-family: var(--font-serif-elegant);
		font-size: clamp(1.2rem, 3vw, 1.8rem);
		color: var(--text-ash-gray);
		font-style: italic;
		margin-bottom: 2rem;
	}

	.ornate-divider {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin: 2rem auto;
		width: 60%;
	}

	.star-icon {
		color: var(--accent-gold);
		font-size: 1.2rem;
	}

	.line {
		height: 1px;
		flex: 1;
		background: linear-gradient(
			90deg,
			transparent,
			var(--border-gold),
			transparent
		);
	}

	.hero-intro {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--text-ash-gray);
		margin-bottom: 1rem;
		padding: 0 1rem;
	}

	/* Content Sections */
	.content-section {
		margin: 3rem 0; /* Reduced to pull content further up */
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid rgba(140, 115, 75, 0.3);
		padding-bottom: 1rem;
	}

	.section-title {
		font-size: 2rem;
		color: var(--accent-gold);
		margin: 0;
	}

	.view-all {
		font-family: var(--font-serif-elegant);
		font-style: italic;
		font-size: 1rem;
		color: var(--text-ash-gray);
		text-decoration: none;
		transition: var(--transition-smooth);
	}

	.view-all:hover {
		color: var(--accent-gold-glow);
		text-shadow: 0 0 8px rgba(207, 170, 107, 0.3);
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	/* Pagination Styles */
	.pagination-item {
		display: none; /* Hidden by default, JS controls visibility */
		flex-direction: column;
		height: 100%;
		animation: fadeIn 0.4s ease forwards;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.pagination-container {
		display: flex;
		justify-content: flex-end;
		align-items: stretch;
		margin-top: 1.5rem; /* Reduced from 3rem to sit much closer to the cards */
		border-bottom: 2px solid var(--accent-gold);
		font-family: var(--font-serif-display);
	}

	:global(.page-btn) {
		background: transparent;
		color: var(--accent-gold);
		border: none;
		padding: 0.3rem 0.8rem; /* Relaxed padding to shrink the buttons */
		font-size: 0.95rem; /* Reduced font size from 1.1rem */
		font-family: inherit;
		cursor: pointer;
		transition: var(--transition-smooth);
		font-weight: 700;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	:global(.page-btn:hover:not(:disabled)) {
		color: var(--bg-dark-night);
		background-color: var(--accent-gold-glow);
	}

	:global(.page-btn.active) {
		background-color: var(--accent-gold);
		color: var(--bg-dark-night);
		/* The slanted aesthetic from the reference */
		clip-path: polygon(10px 0, 100% 0, 100% 100%, 0 100%);
		padding: 0.3rem 1.2rem 0.3rem 1.4rem;
		margin-left: -5px; /* Overlap to create slant effect */
		z-index: 2;
	}

	:global(.page-btn:disabled) {
		color: rgba(207, 170, 107, 0.3);
		cursor: not-allowed;
	}

	:global(.page-nav-text) {
		font-family: var(--font-serif-elegant);
		text-transform: lowercase;
		font-weight: normal;
		font-style: italic;
		letter-spacing: 0.05em;
		font-size: 0.85rem;
	}

	.collections-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.collection-item {
		position: relative;
		min-height: 200px; /* Readjusted slightly since we removed the "Read Collection" link */
		padding: 2rem 1.5rem;
		display: flex;
		flex-direction: column;
		justify-content: center; /* Center the content vertically when not constrained */
		align-items: center;
		text-align: center;
		border: 1px solid var(--border-gold);
		overflow: hidden;
		transition: var(--transition-smooth);
		text-decoration: none;
		flex: 1;
		width: 100%;
	}

	.collection-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
		opacity: 0.5;
		transition: var(--transition-smooth);
	}

	.collection-item:hover .collection-bg {
		opacity: 0.8;
		transform: scale(1.05);
	}

	.collection-item:hover {
		border-color: var(--accent-gold-glow);
		box-shadow: var(--shadow-celestial);
	}

	.collection-title {
		position: relative;
		z-index: 2;
		font-family: var(--font-serif-display);
		font-size: 1.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent-gold-glow);
		margin-top: 0;
		margin-bottom: 0.8rem;
	}

	.collection-lore {
		position: relative;
		z-index: 2;
		font-family: var(--font-body);
		font-size: 0.95rem;
		line-height: 1.5;
		color: rgba(209, 200, 179, 0.85); /* Brighter parchment */
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 4; /* Up to 4 lines before truncation to maintain a smart aspect ratio */
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 900px) {
		.card-grid,
		.collections-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.section-header {
			flex-direction: column;
			gap: 1rem;
		}

		.pagination-container {
			justify-content: center;
		}
	}

	@media (max-width: 600px) {
		.card-grid,
		.collections-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	// Reusable Client-side pagination logic
	document.addEventListener("DOMContentLoaded", () => {
		function setupPagination(
			containerId: string,
			gridId: string,
			itemSelector: string,
		) {
			const container = document.getElementById(containerId);
			const grid = document.getElementById(gridId);

			if (!container || !grid) return;

			const totalItems = parseInt(
				container.getAttribute("data-total") || "0",
				10,
			);
			if (totalItems === 0) return;

			const itemsPerPage = 3;
			const totalPages = Math.ceil(totalItems / itemsPerPage);
			let currentPage = 1;

			const items = grid.querySelectorAll(itemSelector);

			function renderItems() {
				const start = (currentPage - 1) * itemsPerPage;
				const end = start + itemsPerPage;

				items.forEach((item, index) => {
					if (index >= start && index < end) {
						(item as HTMLElement).style.display = "flex";
					} else {
						(item as HTMLElement).style.display = "none";
					}
				});
			}

			function renderControls() {
				if (!container) return;
				container.innerHTML = "";

				if (totalPages <= 1) return; // No pagination needed

				// Prev Button
				const prevBtn = document.createElement("button");
				prevBtn.className = "page-btn page-nav-text";
				prevBtn.innerHTML = "« previous";
				prevBtn.disabled = currentPage === 1;
				prevBtn.addEventListener("click", () => {
					if (currentPage > 1) {
						currentPage--;
						updateView();
					}
				});
				container.appendChild(prevBtn);

				// Numbered Buttons
				for (let i = 1; i <= totalPages; i++) {
					const numBtn = document.createElement("button");
					numBtn.className = `page-btn ${i === currentPage ? "active" : ""}`;
					numBtn.innerText = i.toString();
					numBtn.addEventListener("click", () => {
						currentPage = i;
						updateView();
					});
					container.appendChild(numBtn);
				}

				// Next Button
				const nextBtn = document.createElement("button");
				nextBtn.className = "page-btn page-nav-text";
				nextBtn.innerHTML = "next »";
				nextBtn.disabled = currentPage === totalPages;
				nextBtn.addEventListener("click", () => {
					if (currentPage < totalPages) {
						currentPage++;
						updateView();
					}
				});
				container.appendChild(nextBtn);
			}

			function updateView() {
				renderItems();
				renderControls();
			}

			// Initial render
			updateView();
		}

		// Initialize for Recent Observations
		setupPagination(
			"observations-pagination",
			"observations-grid",
			".obs-item",
		);

		// Initialize for Constellations
		setupPagination(
			"constellations-pagination",
			"constellations-grid",
			".const-item",
		);
	});
</script>
